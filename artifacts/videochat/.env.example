# ── Supabase (get these from your Supabase project dashboard) ──────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API URL (your Railway deployment URL) ──────────────────────────────
# Leave blank in dev (uses window.location.origin via the Replit proxy)
# Set to your Railway backend URL in production:
VITE_API_URL=https://your-backend.up.railway.app
