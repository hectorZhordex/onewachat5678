{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/videochat run build",
  "outputDirectory": "artifacts/videochat/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
